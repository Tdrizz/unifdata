NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Stripe Connect (integration sync for user Stripe accounts)
STRIPE_CLIENT_ID=
STRIPE_CLIENT_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional legacy compatibility for older Supabase helpers.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# AI features (Gemini — used by Data Keeper only; do not remove)
GEMINI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=  # alias for GEMINI_API_KEY
# GEMINI_MODEL=gemini-2.0-flash   # optional: override default model

# AI features (OpenRouter — multi-vendor routing for chat, agents, workers)
OPENROUTER_API_KEY=

# Google Sheets integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_API_KEY=
NEXT_PUBLIC_GOOGLE_PICKER_APP_ID=

# QuickBooks integration
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_SANDBOX=false

# Square integration
SQUARE_CLIENT_ID=
SQUARE_CLIENT_SECRET=

# HubSpot integration
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Jobber integration
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Twilio — SMS sending and inbound webhook validation
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Mailgun — email sending and inbound webhook validation
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=
MAILGUN_WEBHOOK_SIGNING_KEY=

# Redis (BullMQ automation queue)
# Local: redis://localhost:6379
# Vercel: use Upstash Redis — set to rediss://... URL
REDIS_URL=redis://localhost:6379

# Upstash Redis (rate limiting — used alongside or instead of REDIS_URL)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# QuickBooks webhook verifier token (from QB developer portal)
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=

# Internal API protection
CRON_SECRET=                   # gates /api/cron/automation
LEAD_INGEST_SECRET=
INBOUND_SYNC_SECRET=           # x-api-key header for POST /api/inbound-sync
SUPABASE_WEBHOOK_SECRET=       # x-webhook-secret header for POST /api/webhooks/db-events

# Admin access (comma-separated emails)
ADMIN_EMAILS=
# Single admin email for internal AI health dashboard (/admin/ai-health)
ADMIN_EMAIL=

# Observability (Langfuse — free cloud tier at langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
